# ─── Database (Supabase) ───────────────────────────────────────────────────────
# Haal op uit: Supabase → Project → Settings → Database → Connection string
# "Transaction pooler" URL (voor Vercel serverless):
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# "Session pooler" of directe URL (voor prisma db push / migraties):
DIRECT_URL="postgresql://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://smartwash.vercel.app"

# ─── Mollie ───────────────────────────────────────────────────────────────────
# Haal op via: mollie.com → Developers → API keys
MOLLIE_API_KEY="live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Gebruik test_xxx voor testen (geen echte betalingen)

# ─── Tuya Smart Plug ──────────────────────────────────────────────────────────
# Haal op via: iot.tuya.com → Cloud → Development → Open API
TUYA_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxx"
TUYA_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TUYA_BASE_URL="https://openapi.tuyaeu.com"
# EU: https://openapi.tuyaeu.com
# US: https://openapi.tuyaus.com

# ─── E-mail (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="jouw@gmail.com"
SMTP_PASS="app-wachtwoord-hier"
SMTP_FROM="SmartWash <jouw@gmail.com>"

# ─── Admin & Scheduler ────────────────────────────────────────────────────────
ADMIN_PIN="1234"
SCHEDULER_SECRET="verander-dit-in-iets-geheims"
